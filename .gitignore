# Python-generated files
__pycache__/
*.py[oc]
*$py.class
*.so
build/
dist/
wheels/
*.egg-info
*.egg

# Virtual environments
.venv
venv/
env/

# 环境变量（含敏感信息）
.env.local
*.local.env

# 用户配置（config.example.yaml 是样例）
config.yaml

# dev 模式日志目录（安装态日志在 ~/Library/Logs 或 $XDG_STATE_HOME）
logs/

# 发版流程写入的 commit hash（dev 模式下从 git 读，PyPI wheel 里不存在）
src/daobidao/_commit.txt

# 测试 / 覆盖率工具产物
.pytest_cache/
.ruff_cache/
.mypy_cache/
.tox/
.cache/
.coverage
htmlcov/
coverage.xml

# Editors
.idea/
*.swp
*.swo
.vscode/*.log

# 操作系统
.DS_Store
Thumbs.db

# Benchmark run 产物 —— 默认 gitignore,被人为标记入库的"基线"放在
# benchmarks/results/baselines/(下方 ! 显式 unignore 回来)
benchmarks/results/*.json
benchmarks/results/*.md
!benchmarks/results/baselines/
