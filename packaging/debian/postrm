#!/bin/bash
set -e

case "$1" in
    purge)
        # 清理运行期产生的 __pycache__(散在 src/whisper_input/ 各子包里)。
        # 真正的 user venv 和用户配置在 XDG_DATA/XDG_CONFIG 下,不归 postrm 管,
        # 保留给用户,升级/重装时不会丢。
        find /opt/whisper-input -type d -name __pycache__ \
            -exec rm -rf {} + 2>/dev/null || true
        echo "[whisper-input] 已清理 __pycache__"
        echo "  用户配置 (~/.config/whisper-input/) 未删除"
        echo "  用户 venv (~/.local/share/whisper-input/) 未删除"
        ;;

    remove)
        # 更新图标缓存和桌面数据库
        if command -v gtk-update-icon-cache &>/dev/null; then
            gtk-update-icon-cache -f /usr/share/icons/hicolor/ 2>/dev/null || true
        fi
        if command -v update-desktop-database &>/dev/null; then
            update-desktop-database /usr/share/applications/ 2>/dev/null || true
        fi
        ;;
esac

exit 0
