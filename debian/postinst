#!/bin/bash
# Whisper Input deb postinst
#
# 本 postinst 严格保持"秒级完成"：只做加组 / 刷图标缓存 / 友好提示，
# 不 curl 装 uv、不 uv sync、不下模型。所有重动作延后到首次启动，
# 由 /usr/bin/whisper-input 的 setup_window.py 在统一窗口里展示进度。
set -e

case "$1" in
    configure)
        # 将安装用户加入 input 组（读取键盘设备需要）
        if [ -n "$SUDO_USER" ]; then
            if ! groups "$SUDO_USER" 2>/dev/null | grep -qw input; then
                usermod -aG input "$SUDO_USER"
                echo "[whisper-input] 已将用户 $SUDO_USER 加入 input 组"
            fi
        fi

        # 更新图标缓存
        if command -v gtk-update-icon-cache >/dev/null 2>&1; then
            gtk-update-icon-cache -f /usr/share/icons/hicolor/ 2>/dev/null || true
        fi

        # 更新桌面数据库
        if command -v update-desktop-database >/dev/null 2>&1; then
            update-desktop-database /usr/share/applications/ 2>/dev/null || true
        fi

        echo ""
        echo "========================================="
        echo "  Whisper Input 安装完成!"
        echo "========================================="
        echo ""
        if [ -n "$SUDO_USER" ]; then
            echo "  1. 用户 $SUDO_USER 已加入 input 组，请注销并重新登录以生效"
        else
            echo "  1. 请确保当前用户在 input 组中:"
            echo "       sudo usermod -aG input \$USER"
            echo "     然后注销重新登录"
        fi
        echo ""
        echo "  2. 需要预装 uv 包管理器（本程序依赖它管理 Python 和依赖）:"
        echo "       curl -LsSf https://astral.sh/uv/install.sh | sh"
        echo ""
        echo "  3. 从应用菜单搜索「语音输入」启动"
        echo "     首次启动会弹出初始化窗口，依次完成："
        echo "       - Python 运行环境下载（约 30MB）"
        echo "       - Python 依赖安装（约 800MB）"
        echo "       - 语音识别模型下载（约 900MB）"
        echo "       - 模型加载到内存"
        echo "     全程约 5-10 分钟，请保持联网"
        echo ""
        echo "========================================="
        ;;
esac

exit 0
